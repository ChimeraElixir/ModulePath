{
  "name": "modulepath",
  "displayName": "ModulePath",
  "description": "Python symbol discovery and import tool — find where any symbol lives, one-click import",
  "version": "0.1.0",
  "publisher": "modulepath",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Other"],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "modulepath.searchImport",
        "title": "ModulePath: Search Import"
      },
      {
        "command": "modulepath.refreshIndex",
        "title": "ModulePath: Refresh Index"
      }
    ],
    "keybindings": [
      {
        "command": "modulepath.searchImport",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus && editorLangId == python"
      }
    ],
    "configuration": {
      "title": "ModulePath",
      "properties": {
        "modulepath.pythonPath": {
          "type": "string",
          "default": "auto",
          "description": "Path to Python interpreter. 'auto' uses VS Code Python extension setting."
        },
        "modulepath.scanOnActivation": {
          "type": "boolean",
          "default": true,
          "description": "Start background indexing when extension activates."
        },
        "modulepath.watchVenv": {
          "type": "boolean",
          "default": true,
          "description": "Watch virtual environment for package changes."
        },
        "modulepath.mergeImports": {
          "type": "boolean",
          "default": true,
          "description": "Merge imports from same module onto one line."
        },
        "modulepath.runtimeFallbackTimeout": {
          "type": "number",
          "default": 2,
          "description": "Max seconds for runtime import fallback."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
